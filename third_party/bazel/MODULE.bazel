module(name = "bazel_protos")

bazel_dep(name = "aspect_bazel_lib", version = "2.22.5")

http_archive = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")

http_archive(
    name = "com_github_bazelbuild_bazel",
    sha256 = "229e999cec4f408946d368af6c33c5137fe999e9966538562f8c90b0de7aa0ad",
    urls = ["https://github.com/bazelbuild/bazel/releases/download/9.1.0/bazel-9.1.0-dist.zip"],
)

# Dependencies of com_github_bazelbuild_bazel
bazel_dep(name = "bazel_skylib", version = "1.9.0")
bazel_dep(name = "grpc-java", version = "1.78.0")
bazel_dep(name = "grpc", version = "1.81.0", repo_name = "com_github_grpc_grpc")
bazel_dep(name = "platforms", version = "1.1.0")
bazel_dep(name = "protobuf", version = "35.1", repo_name = "com_google_protobuf")
bazel_dep(name = "rules_cc", version = "0.2.18")
bazel_dep(name = "rules_go", version = "0.61.1")
bazel_dep(name = "rules_java", version = "9.6.1")
bazel_dep(name = "rules_jvm_external", version = "7.0")
bazel_dep(name = "rules_license", version = "1.0.0")
bazel_dep(name = "rules_pkg", version = "1.2.0")
bazel_dep(name = "rules_python", version = "1.9.1")

maven = use_extension("@rules_jvm_external//:extensions.bzl", "maven")
use_repo(maven, "maven")
