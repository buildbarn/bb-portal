load("@aspect_bazel_lib//lib:write_source_files.bzl", "write_source_file")
load("//protobuf/private:proto_files.bzl", "PROTO_FILES")

exports_files(
    [key + ".proto" for key in PROTO_FILES.keys()],
)

[write_source_file(
    name = name + "_proto",
    in_file = "//protobuf/private:%s_proto_src" % name,
    out_file = ":%s.proto" % name,
    suggested_update_target = ":protobuf",
) for name in PROTO_FILES.keys()]

write_source_file(
    name = "protobuf",
    additional_update_targets = [
        ":%s_proto" % name
        for name in PROTO_FILES.keys()
    ],
)
